{
  "expo": {
    "name": "SpinWheelApp",
    "slug": "rn-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "plugins": [
      "./plugins/withWidget"
    ],
    "splash": {
      "image": "./assets/spinwheel.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spinwheelapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#121212"
      },
      "package": "com.spinwheelapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
